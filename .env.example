# App
NODE_ENV=development
WEB_PORT=3000
API_PORT=4000
API_URL=http://localhost:4000
WEB_URL=http://localhost:3000

# Database
DATABASE_URL="file:../../jarvis.db"

# LLM Provider
LLM_PROVIDER=mock
ENABLE_REAL_LLM=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Streaming
ENABLE_STREAMING=true
STREAMING_CHUNK_DELAY_MS=25

# Voice
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
VOICE_PROVIDER=mock

# Social Metrics
ENABLE_SOCIAL_METRICS=true

# Zernio Social Metrics
ENABLE_ZERNIO=false
ZERNIO_API_KEY=
ZERNIO_BASE_URL=https://zernio.com/api/v1
ZERNIO_READ_ONLY_MODE=true
ZERNIO_FALLBACK_TO_MOCK=true
ZERNIO_DEFAULT_LIMIT=10

# Notion Project Intelligence
ENABLE_NOTION=false
NOTION_API_KEY=
NOTION_TASKS_DATABASE_ID=
NOTION_PROJECTS_DATABASE_ID=

# Notion property mapping (defaults are shown)
NOTION_TASK_TITLE_PROPERTY=Name
NOTION_TASK_STATUS_PROPERTY=Status
NOTION_TASK_ASSIGNEE_PROPERTY=Assignee
NOTION_TASK_DUE_DATE_PROPERTY=Due
NOTION_TASK_PROJECT_PROPERTY=Project
NOTION_TASK_PRIORITY_PROPERTY=Priority

NOTION_PROJECT_TITLE_PROPERTY=Name
NOTION_PROJECT_STATUS_PROPERTY=Status
NOTION_PROJECT_OWNER_PROPERTY=Owner
NOTION_PROJECT_PROGRESS_PROPERTY=Progress
NOTION_PROJECT_DUE_DATE_PROPERTY=Due

# Composio Tool Gateway (optional — external tools via Composio)
COMPOSIO_API_KEY=
ENABLE_COMPOSIO=false
COMPOSIO_USER_ID=local-user

# Security
COMPOSIO_READ_ONLY_MODE=true
COMPOSIO_REQUIRE_APPROVAL_FOR_WRITE=true

# Allowlist
COMPOSIO_ALLOWED_TOOLKITS=notion,gmail,googlecalendar
COMPOSIO_ALLOWED_ACTIONS=

# Notion via Composio, optional
ENABLE_COMPOSIO_NOTION=false
NOTION_PROVIDER=composio
NOTION_DEFAULT_PARENT_PAGE_ID=
NOTION_DEFAULT_DATABASE_ID=
NOTION_READ_ONLY_MODE=true
NOTION_FALLBACK_TO_MOCK=false
# Canonical flag for Notion writes; if omitted, Jarvis falls back to COMPOSIO_REQUIRE_APPROVAL_FOR_WRITE
REQUIRE_APPROVAL=true

# YouTube public metrics (works without key — uses mock data by default)
ENABLE_YOUTUBE_REAL_METRICS=false
YOUTUBE_API_KEY=

# Future integrations (placeholder — not implemented yet)
ENABLE_INSTAGRAM_REAL_METRICS=false
INSTAGRAM_ACCESS_TOKEN=

ENABLE_TIKTOK_REAL_METRICS=false
TIKTOK_ACCESS_TOKEN=

# Feature flags
ENABLE_VOICE=false
ENABLE_APPROVALS=true
ENABLE_MOCK_CALENDAR=true
ENABLE_LOCAL_COMMANDS=false

# Security
APPROVAL_TIMEOUT_MS=300000
MAX_TOOL_EXECUTION_MS=30000
