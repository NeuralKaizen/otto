    "@wattson/skills": "workspace:*",
    "@wattson/voice": "workspace:*",
    "@prisma/client": "^5.14.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.0",
    "pino": "^9.2.0",
    "tsx": "^4.16.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
