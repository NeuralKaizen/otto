{
  "name": "wattson",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "pnpm --filter @wattson/web dev",
    "dev:api": "pnpm --filter @wattson/api dev",
    "dev:desktop": "concurrently --kill-others -n api,web,tauri -c blue,green,cyan \"pnpm dev:api\" \"pnpm dev:web\" \"pnpm --filter @wattson/desktop dev:desktop\"",
    "build": "turbo run build",
    "build:web": "pnpm --filter @wattson/web build",
    "build:desktop": "pnpm --filter @wattson/web build && pnpm --filter @wattson/desktop build:desktop",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "db:generate": "pnpm --filter @wattson/memory db:generate",
    "db:migrate": "pnpm --filter @wattson/memory db:migrate",
    "db:studio": "pnpm --filter @wattson/memory db:studio",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "turbo": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
